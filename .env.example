# ----------------------------------------------------------------------------
# Agora configuration. Copy to .env for local development.
# Every value is optional: with none set, Agora runs in a fully deterministic
# demo-safe mode (in-memory store + simulated LLM) so the demo never breaks.
# ----------------------------------------------------------------------------

# HTTP port (Scalingo injects this automatically in production).
PORT=3000

# Node environment.
NODE_ENV=development

# Redis connection. On Scalingo, the Redis addon injects SCALINGO_REDIS_URL.
# If absent, Agora falls back to an in-process store (single-instance only).
# REDIS_URL=redis://localhost:6379

# LLM provider. Auto-detected from the keys below.
# Priority: anthropic -> openai -> simulation (no key required).
# LLM_PROVIDER=auto

# Anthropic (recommended). Latest model id shown.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI (alternative).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Max autonomous steps a single learning run may take (safety bound).
MAX_RUN_STEPS=60
